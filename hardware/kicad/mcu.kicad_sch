		(uuid "8c222a9a-6a2d-4988-a6f8-58c903faf528")
	)
	(text "Low Speed External crystal\nFor RTC"
		(exclude_from_sim no)
		(at 216.916 56.642 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "98df82d8-fb97-4c87-98fd-9ba45324b71b")
	)
	(text "UART RX SIGNALS REFER TO THE MCU RX PIN,\nUART TX SIGNALS REFER TO THE MCU TX PIN.\nTHEREFORE, TX SIGNALS SHALL BE CONNECTED TO RX PINS ON PERIPHERALS\nAND RX SIGNALS SHALL BE CONNECTED TO TX PINS ON PERIPHERALS."
		(exclude_from_sim no)
		(at 291.846 159.766 0)
		(effects
			(font
				(size 1.27 1.27)
				(color 255 0 0 1)
			)
			(justify left)
		)
		(uuid "ac4ad731-38ad-4a9f-9db1-9ef1ac338337")
	)
	(text "DERATING\nMaximum current on any\nI/O pin 20mA.\nMaximum current on any\nVDD pin 100mA.\nMaximum voltage 3V3."
		(exclude_from_sim no)
		(at 18.288 54.102 0)
		(effects
			(font
				(size 1.27 1.27)
				(color 255 0 0 1)
			)
			(justify left)
		)
		(uuid "af50d715-b205-4b07-94b7-524cef32b52c")
	)
	(text "High Speed External crystal\nFor system clock"
		(exclude_from_sim no)
		(at 250.444 56.642 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "af56c42e-2f91-44f1-b8f2-2946be9ea628")
	)
	(text "Digital supply voltage with decoupling capacitors."
		(exclude_from_sim no)
		(at 168.148 17.526 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "e19aa851-c7ec-4c33-abc0-d242abe52b10")
	)
	(text_box "## MCU (STM32H753ZIT6)\n\n## RÔLE : Calcul et contrôle central de l'OBC. Il pilote les bus, gère les interruptions, et assure la logique système. \n\nFONCTIONNEMENT :\nAlimentation en 3V3 avec découplage multi condensateurs, et domaine analogique 3V3A pour VDDA et VREF+ avec filtrage dédié. L'architecture de découplage suit une recommandation de référence (AN4938). \nHorloges externes, quartz HSE pour l'horloge système et quartz LSE pour le RTC. \nBoot et reset, BOOT0 par défaut à 0, straps PDR_ON ou PDR_OFF pour activer ou non le Power Down Reset, et NRST pour le reset matériel. \nConvention de nommage, les signaux UART RX et TX sont nommés côté broche MCU, et les signaux actifs bas sont repérés par la lettre N. \nLes pull-up internes du STM32H7 sont utilisés pour maintenir les signaux actifs bas à 1 quand ils ne sont pas utilisés. \n------------------------------------------\n\nREMARQUE :\n"
		(exclude_from_sim no)
		(at 215.9 87.63 0)
		(size 67.31 49.53)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "9fdf86d9-f6e8-42e4-9f02-0f3592b9badd")
	)
