		(uuid "a893736e-b22b-431e-8a16-e8374bf65014")
	)
	(text_box "MRAM (Mémoire non volatile, SPI Quad)\n--------------------------------------------\nRÔLE : Stockage non volatile rapide pour l'OBC, interface QSPI via MRAM_NCS, MRAM_CLK, MRAM_IO_0 à MRAM_IO_3. \n--------------------------------------------\nFONCTIONNEMENT :\nLa MRAM est alimentée en +3V3 avec découplage local 10 µF et 100 nF. Le signal MRAM_CLK passe par une résistance série 22 Ω proche de la broche CLK pour limiter les réflexions. \n--------------------------------------------\n\nREMARQUE : Tension max 3V3. Courant max par pin 40 mA. \n"
		(exclude_from_sim no)
		(at 194.31 20.32 0)
		(size 71.12 44.45)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "c74da4cb-4109-4d72-ac89-26fbd99305cb")
	)
